#!/usr/bin/env bash
latest=$(git tag --sort=-v:refname | head -1)
semvermajor=$(echo "$latest" | sed 's/v\([0-9]*\)\..*/\1/')
semverminor=$(echo "$latest" | sed 's/v[0-9]*\.\([0-9]*\)\..*/\1/')
semverpatch=$(echo "$latest" | sed 's/.*\.\([0-9]*\)$/\1/')

autoconfirm=0
for arg in "$@"; do
    if test "$arg" = "-y"; then
        autoconfirm=1
    fi
done

confirm () {
    local version=$1
    if test $autoconfirm -eq 1; then return 0; fi
    read -p "Tag $version? [y/N] " answer
    test "$answer" = "y"
}

tag () {
    git tag -a "v$1.$2.$3" -m "release v$1.$2.$3"
    echo "Tagged v$1.$2.$3"
}

push () {
    git push "$1" &> /dev/null && \
    git push "$1" "v$2.$3.$4" &> /dev/null
    echo "Pushed v$2.$3.$4"
}

if test $# -lt 1; then
    git tag --sort=-v:refname | head -1
    exit
fi

cmd=$1

case $cmd in
    patch)
        tag "$semvermajor" "$semverminor" "$((semverpatch + 1))"
        ;;
    minor)
        tag "$semvermajor" "$((semverminor + 1))" "0"
        ;;
    major)
        newver="v$((semvermajor + 1)).0.0"
        confirm "$newver" && tag "$((semvermajor + 1))" "0" "0"
        ;;
    push)
        remote=$(git config branch."$(git rev-parse --abbrev-ref HEAD)".remote 2>/dev/null || echo "origin")
        pushall=0
        notags=0
        for arg in "$@"; do
            if test "$arg" = "--all"; then pushall=1; fi
            if test "$arg" = "--no-tags"; then notags=1; fi
        done
        if test $notags -eq 1 && test $pushall -eq 1; then
            for r in $(git remote); do git push "$r" && echo "Pushed to $r"; done
        elif test $notags -eq 1; then
            git push "$remote" && echo "Pushed to $remote"
        elif test $pushall -eq 1; then
            for r in $(git remote); do push "$r" "$semvermajor" "$semverminor" "$semverpatch"; done
        else
            push "$remote" "$semvermajor" "$semverminor" "$semverpatch"
        fi
        ;;
    *)
        echo "Usage: git release [patch|minor|major|push] [-y] [-a] [--no-tags]"
        echo "    patch/minor/major: tag the next version (-y to skip confirmation)"
        echo "    push: push commits and tag to tracking remote (-a for all remotes, --no-tags to skip tag)"
        exit 1
        ;;
esac

