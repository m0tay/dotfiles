#!/bin/sh

# File preview handler for lf.

set -C -f
IFS="$(printf '%b_' '\n')"; IFS="${IFS%_}"

case "$(file --dereference --brief --mime-type -- "$1")" in
	image/*) 
		if command -v exiftool >/dev/null 2>&1; then
			exiftool "$1"
		else
			echo "Image: $1"
		fi
		;;
	text/html) 
		if command -v lynx >/dev/null 2>&1; then
			lynx -width="$4" -display_charset=utf-8 -dump "$1" 2>/dev/null
		else
			cat "$1"
		fi
		;;
	text/troff) man ./ "$1" | col -b ;;
	text/* | */xml | application/json | application/x-ndjson) 
		if command -v bat >/dev/null 2>&1; then
			bat -p --theme ansi --terminal-width "$(($4-2))" -f "$1"
		else
			cat "$1"
		fi
		;;
	audio/* | application/octet-stream) 
		if command -v mediainfo >/dev/null 2>&1; then
			mediainfo "$1"
		elif command -v exiftool >/dev/null 2>&1; then
			exiftool "$1"
		else
			echo "Audio file: $1"
		fi
		;;
	video/*)
		if command -v mediainfo >/dev/null 2>&1; then
			mediainfo "$1"
		elif command -v exiftool >/dev/null 2>&1; then
			exiftool "$1"
		else
			echo "Video file: $1"
		fi
		;;
	*/pdf)
		if command -v pdftotext >/dev/null 2>&1; then
			pdftotext -l 2 "$1" - 2>/dev/null
		else
			echo "PDF: $1"
		fi
		;;
	*/epub+zip|*/mobi*)
		echo "E-book: $1"
		;;
	application/*zip) 
		if command -v unzip >/dev/null 2>&1; then
			unzip -l "$1"
		else
			echo "Archive: $1"
		fi
		;;
	*opendocument*) 
		if command -v odt2txt >/dev/null 2>&1; then
			odt2txt "$1"
		else
			echo "OpenDocument: $1"
		fi
		;;
	application/pgp-encrypted) gpg -d -- "$1" 2>/dev/null || echo "Encrypted file" ;;
esac
exit 1

