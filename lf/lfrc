# Luke's lf settings (adapted for macOS)


# Note on Image Previews
# Image previews disabled for speed. Shows file metadata instead.
# The scope file (~/.config/lf/scope) generates text-based previews.

# Basic vars
set shellopts '-eu'
set ifs "\n"
set scrolloff 10
set period 1
set hiddenfiles ".*:*.aux:*.log:*.bbl:*.bcf:*.blg:*.run.xml"
set cleaner '~/.config/lf/cleaner'
set previewer '~/.config/lf/scope'
set autoquit true

cmd mkdir $mkdir -p "$@"

cmd setbg "$1"

cmd quicklook $open "$f"

# Bindings
map H cd ~
map g top
map D delete
map E extract
map C copyto
map M moveto
map <c-n> push :mkdir<space>""<left>
map <c-r> reload
map <c-s> set hidden!
map <enter> shell
map x $$f
map X !$f

map A :rename; cmd-end # at the very end
map I :rename; cmd-home # at the very beginning

map <c-e> down
map <c-y> up

map o quicklook
