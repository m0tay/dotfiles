{
  "calls": {
    "mute_on_join": true
  },
  "terminal": {
    "shell": "system"
  },
  "search": {
    "regex": true
  },
  "relative_line_numbers": "enabled",
  "buffer_line_height": "standard",
  "buffer_font_size": 20.0,
  "buffer_font_family": "0xProto Nerd Font Propo",
  "theme": {
    "mode": "system",
    "light": "Neovim default dark",
    "dark": "Neovim default dark"
  },
  "vim_mode": true,
  "helix_mode": false
}
