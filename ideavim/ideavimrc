" Set leader key
let mapleader = " "

" Line numbers
set number
set relativenumber

set which-key
set timeoutlen=5000

" Indentation
set expandtab
set shiftwidth=4
set tabstop=4
set softtabstop=4
set smarttab
set autoindent
set smartindent

" Search behavior
set ignorecase
set smartcase
set incsearch
set hlsearch

" Visual enhancements
set cursorline
set showcmd
set visualbell
set scrolloff=10
set wrap
set textwidth=80

" Split behavior
set splitright
set splitbelow

" File navigation
set path+=**
set wildmenu
set hidden
set ttyfast
set laststatus=2
set showmode
set ruler

" Center cursor after scrolling
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" Center cursor after search
nnoremap n nzzzv
nnoremap N Nzzzv

nnoremap <Esc> :nohlsearch<CR>
vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv


" Arrow key reminders
nnoremap <Left> :echo "Use h to move!!"<CR>
nnoremap <Right> :echo "Use l to move!!"<CR>
nnoremap <Up> :echo "Use k to move!!"<CR>
nnoremap <Down> :echo "Use j to move!!"<CR>